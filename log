#!/usr/bin/env node
/*
 * climblog quick logger — one command to log today's entry and push it.
 *
 *   ./log            interactive: prompts, writes entry, commits, pushes
 *   ./log --no-git   write the entry file only (no commit/push)
 *
 * Inputs are constrained to codebook values, so this CLI cannot produce a
 * schema-invalid entry. CI (scripts/validate.py) remains the backstop.
 *
 * Climbing sessions log each climb individually (grade in the venue's own
 * grading system, attempts, sent, repeat). Gyms are first-class entities in
 * gyms/ — the first session at a new gym sets up its grading system once,
 * and every later session reuses it.
 */
"use strict";

const fs = require("fs");
const path = require("path");
const readline = require("readline");
const { execFileSync } = require("child_process");

const ROOT = __dirname;
const NO_GIT = process.argv.includes("--no-git");
// Kaya backfill mode: chains multiple backdated sessions in one run, stamps
// source: kaya, and replaces the attempts/sent prompts with a result shortcut
// using the documented estimation convention (see codebook.md):
//   s = send (attempts 5)   f = fail (10)   ps = project send (20)   pf = project fail (30)
//   <n>s / <n>f = KNOWN attempts (e.g. 1s = filmed flash) — never flagged estimated
const KAYA = process.argv.includes("--kaya");

// Interactive: readline. Piped stdin (tests/automation): buffer all lines up
// front and answer from the queue — readline drops lines that arrive between
// question() calls.
let ask, closeInput;
if (process.stdin.isTTY) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  ask = (q) => new Promise((res) => rl.question(q, (a) => res(a.trim())));
  closeInput = () => rl.close();
} else {
  const queued = fs.readFileSync(0, "utf8").split("\n");
  ask = (q) => {
    const next = queued.shift();
    if (next === undefined) {
      // piped input exhausted — abort rather than defaulting every prompt
      console.log("\n[piped input exhausted — aborting]");
      process.exit(2);
    }
    const a = next.trim();
    process.stdout.write(q + a + "\n");
    return Promise.resolve(a);
  };
  closeInput = () => {};
}

// ---------- prompt helpers ----------

function localToday(offsetDays = 0) {
  const d = new Date();
  d.setDate(d.getDate() + offsetDays);
  const p = (n) => String(n).padStart(2, "0");
  return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
}

function shortId() {
  const chars = "abcdefghijklmnopqrstuvwxyz0123456789";
  let s = "";
  for (let i = 0; i < 4; i++) s += chars[Math.floor(Math.random() * chars.length)];
  return s;
}

function slugify(s) {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "") || "x";
}

async function askDate() {
  const a = await ask(`date [today ${localToday()}, or "y" for yesterday, or YYYY-MM-DD]: `);
  if (a === "" || a.toLowerCase() === "t") return localToday();
  if (a.toLowerCase() === "y") return localToday(-1);
  if (/^\d{4}-\d{2}-\d{2}$/.test(a)) {
    if (a > localToday()) {
      const ok = await ask(`  ${a} is in the future — sure? [y/N]: `);
      if (ok.toLowerCase() !== "y") return askDate();
    }
    return a;
  }
  console.log("  format: YYYY-MM-DD");
  return askDate();
}

async function askInt(label, min, max, optional = true) {
  const a = await ask(`${label}${optional ? " (enter to skip)" : ""}: `);
  if (a === "" && optional) return null;
  const n = parseInt(a, 10);
  if (Number.isInteger(n) && n >= min && n <= max) return n;
  console.log(`  need an integer ${min}-${max}`);
  return askInt(label, min, max, optional);
}

async function askChoice(label, choices, optional = false) {
  const menu = Object.entries(choices).map(([k, v]) => `${k}=${v}`).join(" ");
  const a = await ask(`${label} [${menu}]${optional ? " (enter to skip)" : ""}: `);
  if (a === "" && optional) return null;
  if (choices[a.toLowerCase()]) return choices[a.toLowerCase()];
  console.log("  pick one of the letters");
  return askChoice(label, choices, optional);
}

async function askMulti(label, choices, optional = true) {
  const menu = Object.entries(choices).map(([k, v]) => `${k}=${v}`).join(" ");
  const a = await ask(`${label}, comma-sep [${menu}]${optional ? " (enter to skip)" : ""}: `);
  if (a === "" && optional) return null;
  const picked = [];
  for (const part of a.split(",").map((s) => s.trim().toLowerCase())) {
    if (!choices[part]) {
      console.log(`  unknown "${part}" — use the letters shown`);
      return askMulti(label, choices, optional);
    }
    if (!picked.includes(choices[part])) picked.push(choices[part]);
  }
  return picked.length ? picked : null;
}

async function askYN(label, defYes) {
  const a = await ask(`${label} [${defYes ? "Y/n" : "y/N"}]: `);
  if (a === "") return defYes;
  return a.toLowerCase() === "y";
}

// ---------- YAML writing ----------

function yScalar(v) {
  if (typeof v === "boolean" || typeof v === "number") return String(v);
  if (/[:#"'\n]/.test(v) || /^\s|\s$/.test(v) || v === "") return JSON.stringify(v);
  return v;
}

function yamlLines(key, v, indent = "") {
  if (v === null || v === undefined) return [];
  if (Array.isArray(v) && v.length && typeof v[0] === "object") {
    const lines = [`${indent}${key}:`];
    for (const item of v) {
      let first = true;
      for (const [k, iv] of Object.entries(item)) {
        if (iv === null || iv === undefined) continue;
        const val = Array.isArray(iv) ? `[${iv.join(", ")}]` : yScalar(iv);
        lines.push(`${indent}  ${first ? "- " : "  "}${k}: ${val}`);
        first = false;
      }
    }
    return lines;
  }
  if (Array.isArray(v)) return [`${indent}${key}: [${v.join(", ")}]`];
  return [`${indent}${key}: ${yScalar(v)}`];
}

function writeEntry(dir, id, fields, notes) {
  const lines = ["---"];
  for (const [k, v] of Object.entries(fields)) lines.push(...yamlLines(k, v));
  lines.push("---");
  const body = notes ? `${notes}\n` : "";
  const file = path.join(ROOT, dir, `${id}.md`);
  fs.writeFileSync(file, lines.join("\n") + "\n" + body);
  return file;
}

// ---------- entity registries ----------

function loadEntities(dir) {
  const full = path.join(ROOT, dir);
  if (!fs.existsSync(full)) return [];
  return fs
    .readdirSync(full)
    .filter((f) => f.endsWith(".md"))
    .map((f) => {
      const text = fs.readFileSync(path.join(full, f), "utf8");
      const get = (k) => (text.match(new RegExp(`^${k}:\\s*(.+)$`, "m")) || [])[1]?.trim();
      // parse circuit list: "  - name: yellow" / "    - name: yellow"
      const circuits = [...text.matchAll(/^\s+-\s+name:\s*(.+)$/gm)].map((m) => m[1].trim());
      return {
        id: get("id"),
        name: get("name"),
        label: get("label") || get("site"),
        status: get("status"),
        grading: get("grading"),
        circuits,
      };
    })
    .filter((e) => e.id);
}

const loadInjuries = () => loadEntities("injuries");
const loadGyms = () => loadEntities("gyms");

// ---------- existing-session awareness ----------

function existingOnDate(date) {
  const dir = path.join(ROOT, "entries", "load-events");
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir).filter((f) => f.startsWith(`${date}--`)).map((f) => {
    const text = fs.readFileSync(path.join(dir, f), "utf8");
    const get = (k) => (text.match(new RegExp(`^${k}:\\s*(.+)$`, "m")) || [])[1]?.trim();
    const climbs = (text.match(/^\s+- grade:/gm) || []).length;
    return { file: path.join(dir, f), rel: `entries/load-events/${f}`, type: get("type"), discipline: get("discipline"), gym_id: get("gym_id"), climbs };
  });
}

function repoValid() {
  const py = fs.existsSync(path.join(ROOT, ".venv", "bin", "python"))
    ? path.join(ROOT, ".venv", "bin", "python") : "python3";
  try {
    execFileSync(py, ["scripts/validate.py"], { cwd: ROOT, stdio: "pipe" });
    return true;
  } catch (e) {
    const out = (e.stdout?.toString() ?? "") + (e.stderr?.toString() ?? "");
    if (/ModuleNotFoundError|No such file/.test(out)) return true; // can't validate here — CI will
    console.log(out.split("\n").filter((l) => l.includes("::error")).slice(0, 6).join("\n"));
    return false;
  }
}

async function openEditor(file) {
  if (!process.stdin.isTTY) { console.log(`  (non-interactive: edit ${file} yourself)`); return; }
  const ed = process.env.EDITOR || "nano";
  for (;;) {
    try { execFileSync(ed, [file], { cwd: ROOT, stdio: "inherit" }); }
    catch { console.log(`  editor exited with error — check ${file}`); }
    if (repoValid()) { console.log("  ✓ valid"); return; }
    const again = await ask("  edit broke validation (errors above) — re-edit? [Y/n]: ");
    if (again.toLowerCase() === "n") { console.log("  ⚠ leaving invalid — CI will be red until fixed"); return; }
  }
}

// returns true to proceed with logging a new entry on this date; false to abort.
// edited files are pushed onto extraFiles so they land in the commit.
async function dateGuard(date, extraFiles) {
  for (;;) {
    const existing = existingOnDate(date);
    if (!existing.length) return true;
    console.log(`${date} already has:`);
    existing.forEach((e, i) => console.log(`  ${i + 1}) ${e.rel} — ${e.discipline ?? e.type}${e.gym_id ? ` (${e.gym_id.split("--")[0]})` : ""} · ${e.climbs} climbs`));
    const a = await ask("[enter=add ANOTHER entry on this date | e=edit existing | x=cancel]: ");
    if (a.toLowerCase() === "x") return false;
    if (a.toLowerCase() === "e") {
      const which = existing.length === 1 ? existing[0]
        : existing[Math.min(existing.length, Math.max(1, parseInt(await ask(`which? [1-${existing.length}]: `), 10) || 1)) - 1];
      await openEditor(which.file);
      extraFiles.push(which.file);
      continue;
    }
    return true;
  }
}

function summarize(fields, notes) {
  console.log(`  ┌ ${fields.date} · ${fields.discipline}${fields.gym_id ? ` · ${fields.gym_id.split("--")[0]}` : ""}${fields.duration_min ? ` · ${fields.duration_min} min` : ""}`);
  for (const c of fields.climbs ?? []) {
    console.log(`  │ ${c.grade}${c.name ? ` "${c.name}"` : ""}${c.wall_angle ? ` ${c.wall_angle}` : ""}${c.styles ? ` [${c.styles.join(",")}]` : ""}${c.board_angle != null ? ` ${c.board_angle}°` : ""} ×${c.attempts}${c.attempts_estimated ? "~" : ""} ${c.sent ? (c.repeat ? "✓rpt" : "✓first") : "✗"}`);
  }
  console.log(`  └ notes: ${notes || "—"}`);
}

// ---------- grades ----------

async function askGrade(prompt, grading, circuits) {
  const a = await ask(prompt);
  if (a === "") return ""; // caller decides if blank = done
  if (a.toLowerCase() === "u") return "u"; // undo signal, handled by climb loop
  if (grading === "v_scale") {
    const m = a.match(/^v(b|\d{1,2})$/i);
    if (m) return `V${m[1].toUpperCase()}`;
    console.log("  V-scale, e.g. V5 or VB");
    return askGrade(prompt, grading, circuits);
  }
  if (grading === "kyu_dan") {
    // normalize to compact form: 5q (kyu) / 1d (dan)
    const m = a.match(/^(\d{1,2})\s*(kyu|k|q|dan|d)$/i);
    if (m) {
      const suffix = /^(k|q)/i.test(m[2]) ? "q" : "d";
      return `${m[1]}${suffix}`;
    }
    console.log("  kyu/dan, e.g. 5q (or 5kyu) / 1d (or 1dan)");
    return askGrade(prompt, grading, circuits);
  }
  // circuit: must be one of the gym's defined levels
  const hit = circuits.find((c) => c.toLowerCase() === a.toLowerCase());
  if (hit) return hit;
  console.log(`  this gym's circuits: ${circuits.join(", ")}`);
  return askGrade(prompt, grading, circuits);
}

// ---------- gym registry ----------

async function pickGym() {
  const gyms = loadGyms();
  if (gyms.length) console.log(`known gyms: ${gyms.map((g) => g.name).join(", ")}`);
  const name = await ask("gym name: ");
  if (!name) return pickGym();

  const found = gyms.find(
    (g) => g.name?.toLowerCase() === name.toLowerCase() || slugify(g.name || "") === slugify(name),
  );
  if (found) return { gym: found, created: null };

  console.log(`new gym "${name}" — one-time grading setup:`);
  const grading = await askChoice("  grading system", {
    v: "v_scale", k: "kyu_dan", c: "circuit",
  });
  const circuits = [];
  if (grading === "circuit") {
    console.log("  define circuit levels, easiest first (blank name = done):");
    for (;;) {
      const cname = await ask(`  level ${circuits.length + 1} name: `);
      if (!cname) {
        if (circuits.length) break;
        console.log("  need at least one level");
        continue;
      }
      const range = await ask(`    approx V range, e.g. V2-V4 (enter to skip): `);
      const m = range.match(/^V(B|\d{1,2})\s*-\s*V(B|\d{1,2})$/i);
      circuits.push({
        name: cname,
        v_min: m ? `V${m[1].toUpperCase()}` : null,
        v_max: m ? `V${m[2].toUpperCase()}` : null,
      });
    }
  }
  const id = `${slugify(name)}--${shortId()}`;
  const file = writeEntry(
    "gyms",
    id,
    { id, name, grading, circuits: circuits.length ? circuits : null },
    "",
  );
  console.log(`✓ wrote ${path.relative(ROOT, file)}`);
  return {
    gym: { id, name, grading, circuits: circuits.map((c) => c.name) },
    created: file,
  };
}

// ---------- climb loop ----------

const STYLES = { c: "crimp", p: "pinch", s: "slopy", d: "dynamic", b: "balance", co: "coordination", po: "power" };
const ANGLES = { s: "slab", v: "vert", o: "overhang" };

// Kaya-backfill estimation convention (user-defined 2026-07-20).
const KAYA_RESULTS = {
  s: { attempts: 5, sent: true },
  f: { attempts: 10, sent: false },
  ps: { attempts: 20, sent: true },
  pf: { attempts: 30, sent: false },
};

async function askResult() {
  const a = await ask("  result [s=send f=fail ps=proj-send pf=proj-fail | <n>s/<n>f known, e.g. 1s]: ");
  const conv = KAYA_RESULTS[a.toLowerCase()];
  if (conv) return { ...conv, estimated: true };
  const m = a.match(/^(\d{1,3})(s|f)$/i);
  if (m) {
    const n = parseInt(m[1], 10);
    if (n >= 1 && n <= 200) return { attempts: n, sent: m[2].toLowerCase() === "s", estimated: false };
  }
  console.log("  s / f / ps / pf, or a known count like 1s, 4f");
  return askResult();
}

async function askRepeat(sent, gymStyle) {
  // one canonical field: repeat = sent this problem on a previous day
  if (gymStyle) {
    if (sent) return !(await askYN("  first send of this problem?", true));
    return askYN("  have you sent this problem before?", false);
  }
  if (sent) return askYN("  repeat (sent this before)?", false);
  return askYN("  have you sent this before?", false);
}

async function climbLoop(discipline, gym) {
  const climbs = [];
  const grading = discipline === "gym" ? gym.grading : "v_scale";
  const circuits = discipline === "gym" ? gym.circuits : [];

  for (;;) {
    const n = climbs.length + 1;
    const c = {};

    if (discipline === "gym") {
      const grade = await askGrade(`climb ${n} — grade (enter=done, u=undo last): `, grading, circuits);
      if (grade === "") break;
      if (grade === "u") {
        if (climbs.length) console.log(`  ↩ removed ${climbs.pop().grade}`);
        else console.log("  nothing to undo");
        continue;
      }
      c.grade = grade;
      const label = await ask("  label (project tracking, enter to skip): ");
      if (label) c.name = label;
      c.wall_angle = await askChoice("  wall", ANGLES);
      c.styles = await askMulti("  styles", STYLES);
    } else {
      const name = await ask(`climb ${n} — name (enter=done, u=undo last): `);
      if (name === "") break;
      if (name.toLowerCase() === "u") {
        if (climbs.length) console.log(`  ↩ removed ${climbs.pop().grade}`);
        else console.log("  nothing to undo");
        continue;
      }
      c.name = name;
      c.grade = await askGrade("  grade: ", "v_scale", []);
      if (c.grade === "") c.grade = await askGrade("  grade (required): ", "v_scale", []);
      if (discipline !== "outdoor") c.board_angle = await askInt("  board angle °", 0, 70, false);
    }

    if (KAYA) {
      const r = await askResult();
      c.attempts = r.attempts;
      if (r.estimated) c.attempts_estimated = true;
      c.sent = r.sent;
    } else {
      c.attempts = await askInt("  attempts", 1, 200, false);
      c.sent = await askYN("  sent?", true);
    }
    c.repeat = await askRepeat(c.sent, discipline === "gym");
    climbs.push(c);
    console.log(`  ✓ climb ${n} logged (${c.grade}${c.sent ? ", sent" : ""})`);
  }
  return climbs;
}

// ---------- record flows ----------

async function logClimbSession(date) {
  const extraFiles = [];
  for (;;) {
    const discipline = await askChoice("discipline", {
      g: "gym", k: "kilter_board", t: "tb2", o: "outdoor",
    });

    let gym = null;
    if (discipline === "gym") {
      const res = await pickGym();
      gym = res.gym;
      if (res.created) extraFiles.push(res.created);
    }

    const duration = await askInt("duration min", 0, 1440);
    const climbs = await climbLoop(discipline, gym);
    const notes = await ask("session notes (enter to skip): ");

    const id = `${date}--${shortId()}`;
    const fields = {
      id,
      type: "climbing_session",
      date,
      source: KAYA ? "kaya" : null,
      discipline,
      gym_id: gym ? gym.id : null,
      duration_min: duration,
      climbs: climbs.length ? climbs : null,
    };

    summarize(fields, notes);
    const ok = await ask("save? [enter=save | r=redo session | d=discard]: ");
    if (ok.toLowerCase() === "r") { console.log("  redoing session from the top…"); continue; }
    if (ok.toLowerCase() === "d") { console.log("  discarded."); return extraFiles; }

    const file = writeEntry("entries/load-events", id, fields, notes);
    const sends = climbs.filter((c) => c.sent).length;
    console.log(`  session: ${climbs.length} climbs, ${sends} sends`);
    return [...extraFiles, file];
  }
}

async function logWorkout(date) {
  const id = `${date}--${shortId()}`;
  const fields = { id, type: "rest_workout", date };
  fields.duration_min = await askInt("duration min", 0, 1440);
  fields.workout_type = await askMulti("workout type", {
    l: "lifting", m: "mobility", a: "antagonist", c: "cardio",
    h: "hangboard", s: "stretching", o: "other",
  });
  fields.rpe = await askInt("RPE 1-10", 1, 10);
  const notes = await ask("notes (enter to skip): ");
  return [writeEntry("entries/load-events", id, fields, notes)];
}

async function logRest(date, type) {
  const id = `${date}--${shortId()}`;
  const notes = await ask("notes (enter to skip): ");
  return [writeEntry("entries/load-events", id, { id, type, date }, notes)];
}

async function logInjuryCheck(date, injury) {
  const id = `${date}--${shortId()}`;
  const fields = { id, injury_id: injury.id, date };
  // A reading dated more than a week back is memory, not observation — mark it.
  const daysBack = (new Date(`${localToday()}T00:00:00`) - new Date(`${date}T00:00:00`)) / 86400000;
  if (daysBack > 7) fields.source = "retrospective";
  fields.pain = await askInt(`  pain 0-10 (${injury.label})`, 0, 10, false);
  fields.load_tolerance = await askChoice("  load tolerance", {
    g: "green", y: "yellow", r: "red",
  });
  const rom = await ask("  ROM note (enter to skip): ");
  if (rom) fields.rom = rom;
  const notes = await ask("  notes (enter to skip): ");
  return writeEntry("entries/symptom-observations", id, fields, notes);
}

async function resolveInjury() {
  const injuries = loadInjuries().sort((a, b) => (a.status === "active" ? -1 : 1));
  if (!injuries.length) { console.log("no injuries tracked."); return []; }
  for (let i = 0; i < injuries.length; i++)
    console.log(`  ${i + 1}) ${injuries[i].label} [${injuries[i].status}]`);
  const n = await askInt("which injury (number)", 1, injuries.length, false);
  const inj = injuries[n - 1];
  if (inj.status === "resolved") { console.log(`"${inj.label}" is already resolved.`); return []; }
  console.log("resolved as of when?");
  const date = await askDate();
  const file = path.join(ROOT, "injuries", `${inj.id}.md`);
  let text = fs.readFileSync(file, "utf8");
  text = text.replace(/^status: active$/m, `status: resolved\nresolved_date: ${date}`);
  fs.writeFileSync(file, text);
  console.log(`✓ "${inj.label}" resolved ${date} — no more check-in prompts`);
  return [file];
}

async function logNewInjury() {
  const site = await askChoice("site", {
    a2: "finger_a2", a4: "finger_a4", fp: "finger_pulley_other",
    ft: "finger_flexor_tendon", em: "elbow_medial", el: "elbow_lateral",
    sh: "shoulder", wr: "wrist", fa: "forearm", kn: "knee", ba: "back", o: "other",
  });
  const label = await ask("label (e.g. 'left ring A2 pulley'): ");
  const onset = await askDate();
  const id = `${slugify(label || site)}--${shortId()}`;
  const notes = await ask("notes (enter to skip): ");
  return [
    writeEntry("injuries", id, { id, site, label: label || null, onset_date: onset, status: "active" }, notes),
  ];
}

// ---------- git ----------

function git(...args) {
  return execFileSync("git", args, { cwd: ROOT, encoding: "utf8" }).trim();
}

function commitAndPush(files, summary) {
  git("add", ...files.map((f) => path.relative(ROOT, f)));
  git("commit", "-m", `log: ${summary}`);
  console.log(`✓ committed: log: ${summary}`);
  try {
    execFileSync("git", ["push"], { cwd: ROOT, stdio: "pipe" });
    console.log("✓ pushed");
  } catch {
    console.log("⚠ push failed (offline?) — entry is committed locally; push later with: git push");
  }
}

// ---------- main ----------

(async function main() {
  try {
    const created = [];
    const kinds = [];

    if (KAYA) {
      // Backfill chain: many backdated sessions in one run, one commit at the end.
      console.log("KAYA BACKFILL — convention: s=send(5) f=fail(10) ps=proj-send(20) pf=proj-fail(30), <n>s/<n>f for known counts");
      let count = 0;
      for (;;) {
        const date = await askDate();
        if (!(await dateGuard(date, created))) {
          if (!(await askYN("log another kaya session?", true))) break;
          continue;
        }
        created.push(...(await logClimbSession(date)));
        count++;
        if (!(await askYN(`session ${count} done — log another kaya session?`, true))) break;
      }
      kinds.push(`kaya backfill, ${count} session${count === 1 ? "" : "s"}`);
      for (const f of created) console.log(`✓ wrote ${path.relative(ROOT, f)}`);
      if (NO_GIT) console.log("(--no-git: skipping commit/push)");
      else if (created.length) commitAndPush(created, kinds[0]);
      closeInput();
      return;
    }

    const kind = await askChoice("log what", {
      c: "climb", w: "workout", r: "rest", n: "nothing", i: "injury-check", x: "new-injury", z: "resolve-injury",
    });

    if (kind === "new-injury") {
      created.push(...(await logNewInjury()));
      kinds.push("new injury");
    } else if (kind === "resolve-injury") {
      created.push(...(await resolveInjury()));
      kinds.push("injury resolved");
    } else if (kind === "injury-check") {
      const injuries = loadInjuries().sort((a, b) => (a.status === "active" ? -1 : 1));
      if (!injuries.length) {
        console.log("no injuries tracked — use x (new-injury) first");
        closeInput();
        return;
      }
      const date = await askDate();
      for (let i = 0; i < injuries.length; i++)
        console.log(`  ${i + 1}) ${injuries[i].label} [${injuries[i].status}]`);
      const n = await askInt("which injury (number)", 1, injuries.length, false);
      created.push(await logInjuryCheck(date, injuries[n - 1]));
      kinds.push("injury-check");
    } else {
      const date = await askDate();
      if (!(await dateGuard(date, created))) {
        if (created.length && !NO_GIT) commitAndPush(created, `${localToday()} (edit)`);
        closeInput();
        return;
      }
      if (kind === "climb") created.push(...(await logClimbSession(date)));
      else if (kind === "workout") created.push(...(await logWorkout(date)));
      else created.push(...(await logRest(date, kind === "rest" ? "rest" : "nothing")));
      kinds.push(kind);

      // Day-of/day-after readings are the most informative — offer check-ins
      // for every active injury after any load event.
      const active = loadInjuries().filter((i) => i.status === "active");
      for (const inj of active) {
        if (await askYN(`log a check-in for "${inj.label}"?`, true)) {
          created.push(await logInjuryCheck(date, inj));
          kinds.push("injury-check");
        }
      }
    }

    for (const f of created) console.log(`✓ wrote ${path.relative(ROOT, f)}`);

    if (NO_GIT) {
      console.log("(--no-git: skipping commit/push)");
    } else if (created.length) {
      const dateTag =
        created.map((f) => /(\d{4}-\d{2}-\d{2})/.exec(path.basename(f))?.[1]).find(Boolean) ??
        localToday();
      commitAndPush(created, `${dateTag} (${kinds.join(", ")})`);
    }
    closeInput();
  } catch (e) {
    console.error(`error: ${e.message}`);
    closeInput();
    process.exit(1);
  }
})();
