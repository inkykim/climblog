#!/usr/bin/env node
/*
 * climblog post CLI — write like you log.
 *
 *   ./post "why my dip took two months"   scaffold + open editor + tidy + commit + push
 *   ./post                                list posts/drafts, pick one to reopen
 *   ./post --no-git ...                   skip commit/push
 *
 * Tidy is deterministic and word-preserving: typographic quotes/dashes,
 * trailing-whitespace trim, blank-line collapse. It never rewrites your words —
 * the site's typography does the "looking good".
 */
"use strict";

const fs = require("fs");
const path = require("path");
const readline = require("readline");
const { execFileSync } = require("child_process");

const ROOT = __dirname;
const NO_GIT = process.argv.includes("--no-git");
const args = process.argv.slice(2).filter((a) => a !== "--no-git");

let ask, closeInput;
if (process.stdin.isTTY) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  ask = (q) => new Promise((res) => rl.question(q, (a) => res(a.trim())));
  closeInput = () => rl.close();
} else {
  const queued = fs.readFileSync(0, "utf8").split("\n");
  ask = (q) => {
    const next = queued.shift();
    if (next === undefined) { console.log("\n[piped input exhausted — aborting]"); process.exit(2); }
    process.stdout.write(q + next.trim() + "\n");
    return Promise.resolve(next.trim());
  };
  closeInput = () => {};
}

const today = () => {
  const d = new Date();
  const p = (n) => String(n).padStart(2, "0");
  return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
};

const slugify = (s) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "").slice(0, 60).replace(/-+$/, "") || "post";

// deterministic, word-preserving tidy
function tidy(text) {
  const [, fm, ...rest] = text.split("---");
  let body = rest.join("---");
  body = body
    .replace(/[ \t]+$/gm, "")                    // trailing whitespace
    .replace(/\n{3,}/g, "\n\n")                  // collapse >1 blank line
    .replace(/(\w)'(\w)/g, "$1’$2")         // apostrophes
    .replace(/"([^"\n]+)"/g, "“$1”")   // double quotes → curly
    .replace(/ -- /g, " — ");               // spaced double hyphen → em dash
  return `---${fm}---${body.replace(/\s*$/, "\n")}`;
}

function repoValid() {
  const py = fs.existsSync(path.join(ROOT, ".venv", "bin", "python"))
    ? path.join(ROOT, ".venv", "bin", "python") : "python3";
  try { execFileSync(py, ["scripts/validate.py"], { cwd: ROOT, stdio: "pipe" }); return true; }
  catch (e) {
    const out = (e.stdout?.toString() ?? "") + (e.stderr?.toString() ?? "");
    if (/ModuleNotFoundError|No such file/.test(out)) return true;
    console.log(out.split("\n").filter((l) => l.includes("::error")).slice(0, 6).join("\n"));
    return false;
  }
}

async function openEditor(file) {
  if (!process.stdin.isTTY) { console.log(`  (non-interactive: edit ${file} yourself)`); return; }
  const ed = process.env.EDITOR || "nano";
  for (;;) {
    try { execFileSync(ed, [file], { cwd: ROOT, stdio: "inherit" }); }
    catch { console.log(`  editor exited with error — check ${file}`); }
    fs.writeFileSync(file, tidy(fs.readFileSync(file, "utf8")));
    if (repoValid()) { console.log("  ✓ tidied + valid"); return; }
    const again = await ask("  broke validation (errors above) — re-edit? [Y/n]: ");
    if (again.toLowerCase() === "n") { console.log("  ⚠ leaving invalid — CI will be red"); return; }
  }
}

function listPosts() {
  const dir = path.join(ROOT, "posts");
  if (!fs.existsSync(dir)) return [];
  return fs.readdirSync(dir).filter((f) => f.endsWith(".md")).sort().reverse().map((f) => {
    const text = fs.readFileSync(path.join(dir, f), "utf8");
    const get = (k) => (text.match(new RegExp(`^${k}:\\s*(.+)$`, "m")) || [])[1]?.trim();
    return { file: path.join(dir, f), rel: `posts/${f}`, title: get("title"), draft: get("draft") === "true" };
  });
}

function git(...a) { return execFileSync("git", a, { cwd: ROOT, encoding: "utf8" }).trim(); }
function commitAndPush(file, summary) {
  git("add", path.relative(ROOT, file));
  git("commit", "-m", `post: ${summary}`);
  console.log(`✓ committed: post: ${summary}`);
  try { execFileSync("git", ["push"], { cwd: ROOT, stdio: "pipe" }); console.log("✓ pushed"); }
  catch { console.log("⚠ push failed — committed locally; push later"); }
}

(async function main() {
  let file, title;

  if (args.length) {
    // new post
    title = args.join(" ");
    const date = today();
    let slug = slugify(title);
    let id = `${date}--${slug}`;
    let n = 2;
    while (fs.existsSync(path.join(ROOT, "posts", `${id}.md`))) id = `${date}--${slug}-${n++}`;
    file = path.join(ROOT, "posts", `${id}.md`);
    const draft = (await ask("draft (hidden from site until you remove the flag)? [y/N]: ")).toLowerCase() === "y";
    const inj = await ask("link an injury id (enter to skip): ");
    const fmLines = [`id: ${id}`, `title: ${JSON.stringify(title)}`, `date: ${date}`];
    if (inj) fmLines.push(`injury_id: ${inj}`);
    if (draft) fmLines.push("draft: true");
    fs.writeFileSync(file, `---\n${fmLines.join("\n")}\n---\n\nWrite here. Markdown subset: ## heading, **bold**, *italic*, [link](url), ![img](path), > quote, - list, ---\n`);
    console.log(`✓ scaffolded ${path.relative(ROOT, file)}`);
  } else {
    // reopen existing
    const posts = listPosts();
    if (!posts.length) { console.log('no posts yet — ./post "your title"'); closeInput(); return; }
    posts.forEach((p, i) => console.log(`  ${i + 1}) ${p.rel} — ${p.title}${p.draft ? " [DRAFT]" : ""}`));
    const n = parseInt(await ask(`which? [1-${posts.length}]: `), 10);
    if (!(n >= 1 && n <= posts.length)) { console.log("never mind."); closeInput(); return; }
    file = posts[n - 1].file;
    title = posts[n - 1].title;
  }

  await openEditor(file);

  if (NO_GIT) console.log("(--no-git: skipping commit)");
  else commitAndPush(file, title);
  closeInput();
})();
