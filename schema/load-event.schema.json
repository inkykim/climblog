{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "load-event.schema.json",
  "title": "Load Event",
  "description": "A climbing session, rest-day workout, or a minimal rest/nothing day.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "date"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique id, matches the filename stem: <date>--<shortid>.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}--[a-z0-9]{2,8}$"
    },
    "type": {
      "enum": ["climbing_session", "rest_workout", "rest", "nothing"]
    },
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "duration_min": { "type": "integer", "minimum": 0, "maximum": 1440 },
    "disciplines": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["boulder", "lead", "top_rope", "board", "autobelay"] },
      "description": "Climbing disciplines trained this session (climbing_session)."
    },
    "location": { "type": "string" },
    "volume": {
      "type": "integer",
      "minimum": 0,
      "description": "Total problems/routes attempted."
    },
    "hardest_send": {
      "type": "string",
      "description": "Hardest clean send this session, e.g. V5 or 5.11c."
    },
    "grades": {
      "type": "array",
      "description": "Optional per-grade breakdown of climbs.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["grade"],
        "properties": {
          "grade": { "type": "string" },
          "discipline": { "enum": ["boulder", "lead", "top_rope", "board", "autobelay"] },
          "result": { "enum": ["send", "flash", "onsight", "attempt", "project"] },
          "count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "workout_type": {
      "type": "array",
      "items": {
        "enum": ["lifting", "mobility", "antagonist", "cardio", "hangboard", "stretching", "other"]
      },
      "description": "For rest_workout days: what the non-climbing training was."
    },
    "rpe": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Session-level rate of perceived exertion (1-10)."
    },
    "notes": { "type": "string" }
  }
}
